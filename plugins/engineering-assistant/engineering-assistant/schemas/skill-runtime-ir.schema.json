{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "skill_id",
    "version",
    "stage",
    "type",
    "prompt_pack",
    "inputs",
    "outputs",
    "routing",
    "risk",
    "quality_gates",
    "source_files"
  ],
  "properties": {
    "skill_id": {
      "type": "string"
    },
    "prompt_pack": {
      "type": "object"
    },
    "routing": {
      "type": "object"
    },
    "risk": {
      "type": "object"
    },
    "source_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
