{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "status",
    "metrics",
    "checks"
  ],
  "properties": {
    "status": {
      "enum": [
        "pass",
        "block"
      ]
    },
    "metrics": {
      "type": "object"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
