{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "technology_categories",
    "review_status",
    "source",
    "exceptions"
  ],
  "properties": {
    "technology_categories": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "persistence_framework": {
      "type": "string"
    },
    "review_status": {
      "enum": [
        "confirmed",
        "waiting_for_input",
        "approved_exception",
        "blocked"
      ]
    },
    "source": {
      "type": "string"
    },
    "exceptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
