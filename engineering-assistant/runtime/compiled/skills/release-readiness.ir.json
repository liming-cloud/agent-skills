{
  "skill_id": "release-readiness",
  "version": "1.0.0",
  "stage": "release_readiness",
  "type": "stage_skill",
  "prompt_pack": {
    "display_name": "Release Readiness",
    "short_description": "判断是否具备发布条件，并输出发布计划、检查清单、回滚计划和 gate 决策。",
    "default_prompt": "使用 release-readiness，先确认语言和必填输入，再输出声明产物与 gate decision。",
    "trigger_description": "Use when the request is about 判断是否具备发布条件，并输出发布计划、检查清单、回滚计划和 gate 决策。；Do not use when 不执行生产发布；不绕过高风险发布审批。",
    "language_policy": {
      "supported": [
        "zh-CN",
        "en"
      ],
      "when_unspecified": "ask_user"
    }
  },
  "inputs": [
    "code-quality-report.json",
    "code-review-report.md",
    "release-standard.md",
    "risk_policy"
  ],
  "outputs": [
