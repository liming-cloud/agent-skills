{
  "skill_id": "code-review",
  "version": "1.0.0",
  "stage": "code_review",
  "type": "stage_skill",
  "prompt_pack": {
    "display_name": "Code Review",
    "short_description": "对代码进行人工评审辅助，按问题、证据、影响、级别、建议和阻断状态输出。",
    "default_prompt": "使用 code-review，先确认语言和必填输入，再输出声明产物与 gate decision。",
    "trigger_description": "Use when the request is about 对代码进行人工评审辅助，按问题、证据、影响、级别、建议和阻断状态输出。；Do not use when 不替代 code-quality-governor；不输出无证据建议。",
    "language_policy": {
      "supported": [
        "zh-CN",
        "en"
      ],
      "when_unspecified": "ask_user"
    }
  },
  "inputs": [
    "code-quality-report.json",
    "changed-files-report.json",
    "implementation-summary.md",
    "repo_context"
  ],
  "outputs": [
    "code-review-report.md",
    "code-review-report.html",
    "review-comments.json",
    "blocker-list.md"
  ],
  "routing": {
    "intent_tags": [
      "code",
      "code-review",
      "code_review",
      "review",
      "stage_skill",
      "对代码进行人工评审辅助",
      "建议和阻断状态输出。",
      "影响",
      "按问题",
      "级别",
      "证据"
    ],
    "positive_triggers": [
      "code-review",
      "Code Review",
      "对代码进行人工评审辅助，按问题、证据、影响、级别、建议和阻断状态输出。"
    ],
    "negative_triggers": [
      "只解释 Code Review 的用途，不执行任务",
      "只咨询说明",
      "不生成产物"
    ],
    "requires": [
      "code-quality-report.json",
      "changed-files-report.json",
      "implementation-summary.md",
      "repo_context"
    ],
    "conflicts_with": [],
    "risk_level": "medium",
    "cost_class": "medium",
    "evidence_required": [
      "blocker 清单为空",
      "所有问题有证据",
      "严重级别一致",
      "静态分析指标已纳入评审",
      "富 HTML 人工走查报告已生成",
      "修复建议可执行"
    ],
    "allow_implicit_invocation": true
  },
  "risk": {
    "risk_level": "medium",
    "allow_implicit_invocation": true,
    "human_approval_required": [
      "blocker 关闭",
      "高风险人工豁免",
      "核心链路评审通过"
    ]
  },
  "quality_gates": [
    "blocker 清单为空",
    "所有问题有证据",
    "严重级别一致",
    "静态分析指标已纳入评审",
    "富 HTML 人工走查报告已生成",
    "修复建议可执行"
  ],
  "workflow": {
    "node_id": "code-review",
    "entry_modes": [
      "auto_flow",
      "from_node",
      "single_node"
    ],
    "next_nodes": []
  },
  "source_files": [
    "skills/code-review/SKILL.md",
    "skills/code-review/contract.yaml",
    "skills/code-review/workflow/node.yaml",
    "skills/code-review/agents/openai.yaml"
  ]
}
