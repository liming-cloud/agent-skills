{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "task_id",
    "source_design",
    "source_checksum",
    "goals",
    "acceptance_criteria",
    "module_boundaries",
    "assumptions"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "source_design": {
      "type": "string"
    },
    "source_checksum": {
      "type": "string"
    },
    "goals": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "module_boundaries": {
      "type": "object"
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
