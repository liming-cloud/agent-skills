{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "root",
    "skill_id",
    "task_id",
    "status",
    "sources",
    "forbidden_sources",
    "missing_required_sources"
  ],
  "properties": {
    "root": {
      "type": "string"
    },
    "skill_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "status": {
      "enum": [
        "pass",
        "block"
      ]
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "kind"
        ]
      }
    },
    "forbidden_sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "missing_required_sources": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
