{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "task_id",
    "title",
    "language",
    "workflow_id",
    "status",
    "control_dir",
    "created_at"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "language": {
      "enum": [
        "zh-CN",
        "en"
      ]
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "enum": [
        "initialized",
        "design_approved",
        "contract_compiled",
        "implementing",
        "quality_running",
        "blocked",
        "succeeded"
      ]
    },
    "control_dir": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "minLength": 1
    },
    "updated_at": {
      "type": "string"
    },
    "project_profile": {
      "type": "object"
    },
    "current_contracts": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
