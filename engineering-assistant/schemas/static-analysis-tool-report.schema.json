{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "root",
    "generated_at",
    "tools",
    "summary"
  ],
  "properties": {
    "root": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "status"
        ]
      }
    },
    "summary": {
      "type": "object"
    }
  }
}
