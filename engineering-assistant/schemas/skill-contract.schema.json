{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "skill_id",
    "version",
    "stage",
    "type",
    "inputs",
    "outputs",
    "quality_gates",
    "workflow_interface",
    "owner"
  ],
  "properties": {
    "skill_id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "version": {
      "type": "string"
    },
    "type": {
      "enum": [
        "stage_skill",
        "cross_cutting_skill",
        "workflow_skill",
        "audit_skill",
        "control_skill"
      ]
    }
  }
}
