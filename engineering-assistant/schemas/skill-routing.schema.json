{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "status",
    "decision",
    "confidence",
    "reason",
    "candidates"
  ],
  "properties": {
    "status": {
      "enum": [
        "selected",
        "rejected",
        "waiting_for_input"
      ]
    },
    "decision": {
      "type": [
        "string",
        "null"
      ]
    },
    "confidence": {
      "type": "number"
    },
    "reason": {
      "type": "string"
    },
    "candidates": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  },
  "additionalProperties": true
}
