{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "rules"
  ],
  "properties": {
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status",
          "severity",
          "confidence",
          "source_evidence",
          "recommended_rule",
          "owner",
          "review_required"
        ]
      }
    }
  }
}
