{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "status",
    "findings",
    "generated_at"
  ],
  "properties": {
    "status": {
      "enum": [
        "pass",
        "block"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "generated_at": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
